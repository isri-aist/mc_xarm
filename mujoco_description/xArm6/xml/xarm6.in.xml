      <geom type="mesh" material="white" group="1"/>
      <joint axis="0 0 1" armature="0.1" range="-6.28319 6.28319" frictionloss="1"/>
      <default class="size1">
        <joint damping="10"/>
      </default>
      <default class="size2">
        <joint damping="5"/>
      </default>
      <default class="size3">
        <joint damping="2"/>
      </default>
      <site size="0.001" rgba="1 0 0 1" group="4"/>
    </default>
  </default>

  <worldbody>
