<mujoco model="xarm5">
  <compiler angle="radian" autolimits="true"
            meshdir="@XARM_DESCRIPTION_SHARE@/meshes/xarm5/visual"/>

  <option integrator="implicitfast"/>

  <asset>
    <material name="white" rgba="1 1 1 1"/>
    <mesh name="link_base" file="link_base.stl"/>
    <mesh name="link1" file="link1.stl"/>
    <mesh name="link2" file="link2.stl"/>
    <mesh name="link3" file="link3.stl"/>
    <mesh name="link4" file="link4.stl"/>
    <mesh name="link5" file="link5.stl"/>
    <mesh name="end_tool" file="@XARM_DESCRIPTION_SHARE@/meshes/end_tool/collision/end_tool.stl"/>
  </asset>

  <default>
    <default class="xarm5">
      <geom type="mesh" material="white" group="1"/>
      <joint axis="0 0 1" armature="0.1" range="-6.28319 6.28319" frictionloss="1"/>
      <default class="size1">
        <joint damping="10"/>
      </default>
      <default class="size2">
        <joint damping="5"/>
      </default>
      <default class="size3">
        <joint damping="2"/>
      </default>
      <site size="0.001" rgba="1 0 0 1" group="4"/>
    </default>
  </default>

  <worldbody>
    <body name="link_base" childclass="xarm5">
      <geom type="mesh" rgba="1 1 1 1" mesh="link_base"/>
      <body name="link1" pos="0 0 0.267">
        <inertial pos="0.00013 0.0294 -0.01239" quat="0.976897 -0.212169 0.00886257 0.0240422" mass="2.3849" diaginertia="0.00570618 0.00530019 0.00294197"/>
        <joint name="joint1" pos="0 0 0" axis="0 0 1" range="-6.28319 6.28319" actuatorfrcrange="-50 50" damping="10" frictionloss="1"/>
        <geom type="mesh" rgba="1 1 1 1" mesh="link1"/>
        <body name="link2" quat="0.707105 -0.707108 0 0">
          <inertial pos="0.03788 -0.2254 0.03447" quat="0.632994 0.750527 0.187997 -0.0261719" mass="2.164" diaginertia="0.0289206 0.0277808 0.00354667"/>
          <joint name="joint2" pos="0 0 0" axis="0 0 1" range="-2.059 2.0944" actuatorfrcrange="-50 50" damping="10" frictionloss="1"/>
          <geom type="mesh" rgba="1 1 1 1" mesh="link2"/>
          <body name="link3" pos="0.0535 -0.2845 0">
            <inertial pos="0.06883 0.22985 0.00102" quat="0.75411 0.568954 -0.247614 0.215165" mass="2.121" diaginertia="0.0382682 0.0373731 0.00349086"/>
            <joint name="joint3" pos="0 0 0" axis="0 0 1" range="-3.927 0.19198" actuatorfrcrange="-30 30" damping="5" frictionloss="1"/>
            <geom type="mesh" rgba="1 1 1 1" mesh="link3"/>
            <body name="link4" pos="0.0775 0.3425 0">
              <inertial pos="0.06489 0.03122 0.00319" quat="-0.224519 0.773365 0.156356 0.571884" mass="1.3169" diaginertia="0.00240435 0.00212066 0.00106127"/>
              <joint name="joint4" pos="0 0 0" axis="0 0 1" range="-1.69297 3.14159" actuatorfrcrange="-20 20" damping="3" frictionloss="1"/>
              <geom type="mesh" rgba="1 1 1 1" mesh="link4"/>
              <body name="link5" pos="0.076 0.097 0" quat="0.707105 -0.707108 0 0">
                <inertial pos="0 -0.00677 -0.01098" quat="0.487612 0.512088 -0.512088 0.487612" mass="0.17" diaginertia="0.000132176 9.3e-05 5.85236e-05"/>
                <joint name="joint5" pos="0 0 0" axis="0 0 1" range="-6.28319 6.28319" actuatorfrcrange="-20 20" damping="3" frictionloss="1"/>
                <geom type="mesh" rgba="0.753 0.753 0.753 1" mesh="end_tool"/>
                <site name="attachment_site"/>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <motor name="act1" joint="joint1" class="size1"/>
    <motor name="act2" joint="joint2" class="size1"/>
    <motor name="act3" joint="joint3" class="size2"/>
    <motor name="act4" joint="joint4" class="size2"/>
    <motor name="act5" joint="joint5" class="size2"/>
  </actuator>

  <sensor>
    <force name="EEForceSensor_fsensor" site="attachment_site"/>
    <torque name="EEForceSensor_tsensor" site="attachment_site"/>
  </sensor>

  <keyframe>
    <key name="home" qpos="0 0 0 .909 0 1.15644 0" ctrl="0 -.247 0 .909 0 1.15644 0"/>
  </keyframe>
</mujoco>
